# Auth.js secret — generate with: openssl rand -hex 32
AUTH_SECRET=

# GitHub OAuth App credentials
# Create an OAuth App at https://github.com/settings/developers
# Callback URL: http://localhost:5173/auth/callback/github (dev)
#               https://yourdomain.com/auth/callback/github (prod)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
